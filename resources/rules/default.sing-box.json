{
    "dns": {
        "servers": [
            {
                "type": "local",
                "tag": "local"
            },
            {
                "type": "udp",
                "tag": "remote",
                "server": "1.1.1.1"
            },
            {
                "type": "udp",
                "tag": "cn",
                "server": "8.8.8.8"
            }
        ],
        "rules": [
            {
                "rule_set": [
                    "geosite-ir"
                ],
                "action": "route",
                "server": "cn"
            },
            {
                "domain_suffix": [
                    ".ir",
                    ".xn--mgba3a4f16a"
                ],
                "action": "route",
                "server": "cn"
            }
        ],
        "final": "remote",
        "strategy": "ipv4_only"
    },
    "inbounds": [
        {
            "tag": "tun-in",
            "type": "tun",
            "address": [
                "172.19.0.1/30"
            ],
            "auto_route": true,
            "mtu": 1400,
            "stack": "gvisor",
            "strict_route": false,
            "route_exclude_address_set": ["geoip-ir"],
            "sniff": true,
            "sniff_override_destination": false,
            "sniff_timeout": "100ms"
        },
        {
            "tag": "socks-in",
            "type": "socks",
            "listen": "127.0.0.1",
            "listen_port": 2333,
            "users": [],
            "tcp_keep_alive": "15m",
            "tcp_fast_open": false,
            "sniff": false
        },
        {
            "tag": "mixed-in",
            "type": "mixed",
            "listen": "127.0.0.1",
            "listen_port": 2334,
            "users": [],
            "tcp_keep_alive": "15m",
            "tcp_fast_open": false,
            "sniff": false
        }
    ],
    "outbounds": [
        {
            "tag": "DIRECT",
            "type": "direct",
            "domain_resolver": {
                "server": "cn"
            },
            "tcp_fast_open": false,
            "tcp_multi_path": false
        },
        {
            "tag": "دکتر‌موبایل‌جایزان",
            "type": "selector",
            "interrupt_exist_connections": false,
            "outbounds": [
                "انتخاب خودکار"
            ]
        },
        {
            "tag": "انتخاب خودکار",
            "type": "urltest",
            "url": "https://www.gstatic.com/generate_204",
            "interval": "30m",
            "tolerance": 50,
            "idle_timeout": "60m",
            "interrupt_exist_connections": false,
            "outbounds": []
        }
    ],
    "route": {
        "rules": [
            {
                "action": "sniff",
                "timeout": "100ms"
            },
            {
                "protocol": "dns",
                "action": "hijack-dns"
            },
            {
                "domain": [
                    "gitlab.com",
                    "gitlab.io",
                    "gitlabusercontent.com",
                    "apple.com",
                    "icloud.com",
                    "icloud-content.com",
                    "apple-cloudkit.com",
                    "apple.news",
                    "applepaydisplay.com",
                    "applepay.com",
                    "aaplimg.com",
                    "apple.co",
                    "applemusic.com",
                    "business.apple.com",
                    "school.apple.com",
                    "appleconnect.apple.com",
                    "itunes.apple.com",
                    "mzstatic.com",
                    "cdn-apple.com",
                    "apple-dns.net"
                ],
                "action": "route",
                "outbound": "DIRECT"
            },
            {
                "rule_set": [
                    "category-ads-all"
                ],
                "action": "reject",
                "method": "drop",
                "no_drop": false
            },
            {
                "ip_is_private": true,
                "action": "route",
                "outbound": "DIRECT"
            },
            {
                "network": "udp",
                "port": [
                    123,
                    53
                ],
                "action": "route",
                "outbound": "DIRECT"
            },
            {
                "clash_mode": "غیرفعال کردن پراکسی",
                "action": "route",
                "outbound": "DIRECT"
            },
            {
                "clash_mode": "پراکسی سراسری",
                "action": "route",
                "outbound": "دکتر‌موبایل‌جایزان"
            },
            {
                "rule_set": [
                    "geosite-ir",
                    "geoip-ir"
                ],
                "action": "route",
                "outbound": "DIRECT"
            },
            {
                "domain_suffix": [
                    ".ir",
                    ".xn--mgba3a4f16a"
                ],
                "action": "route",
                "outbound": "DIRECT"
            }
        ],
        "auto_detect_interface": true,
        "final": "دکتر‌موبایل‌جایزان",
        "default_domain_resolver": {
            "server": "cn"
        },
        "rule_set": [
            {
                "tag": "geoip-ir",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geoip-ir.srs",
                "download_detour": "DIRECT",
                "update_interval": "168h"
            },
            {
                "tag": "geosite-ir",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-ir.srs",
                "download_detour": "DIRECT",
                "update_interval": "168h"
            },
            {
                "tag": "category-ads-all",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
                "download_detour": "DIRECT",
                "update_interval": "168h"
            }
        ]
    },
    "experimental": {
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "store_fakeip": false
        },
        "clash_api": {
            "default_mode": "پراکسی بین‌المللی",
            "external_controller": "127.0.0.1:9090",
            "secret": ""
        }
    }
}
