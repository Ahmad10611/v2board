{
    "dns": {
        "rules": [
            {
                "outbound": [
                    "any"
                ],
                "server": "local"
            },
            {
                "clash_mode": "جهانی",
                "server": "remote"
            },
            {
                "clash_mode": "مستقیم",
                "server": "local"
            }
        ],
        "servers": [
            {
                "address": "https://1.1.1.1/dns-query",
                "detour": "💉دکتر‌موبایل‌جایزان",
                "tag": "remote"
            },
            {
                "address": "8.8.8.8",
                "detour": "direct",
                "tag": "local"
            },
            {
                "address": "rcode://success",
                "tag": "block"
            }
        ],
        "strategy": "ipv4_only"
    },
    "experimental": {
        "cache_file": {
            "enabled": true
        },
        "clash_api": {
            "default_mode": "قوانین",
            "external_controller": "127.0.0.1:9090",
            "secret": ""
        }
    },
    "inbounds": [
        {
            "auto_route": true,
            "domain_strategy": "prefer_ipv4",
            "endpoint_independent_nat": true,
            "inet4_address": "172.19.0.1/30",
            "inet6_address": "2001:0470:f9da:fdfa::1/64",
            "mtu": 9000,
            "sniff": true,
            "sniff_override_destination": true,
            "stack": "system",
            "strict_route": true,
            "type": "tun"
        },
        {
            "domain_strategy": "prefer_ipv4",
            "listen": "127.0.0.1",
            "listen_port": 2333,
            "sniff": true,
            "sniff_override_destination": true,
            "tag": "socks-in",
            "type": "socks",
            "users": []
        },
        {
            "domain_strategy": "prefer_ipv4",
            "listen": "127.0.0.1",
            "listen_port": 2334,
            "sniff": true,
            "sniff_override_destination": true,
            "tag": "mixed-in",
            "type": "mixed",
            "users": []
        }
    ],
    "outbounds": [
        {
            "type": "selector",
            "tag": "💉دکتر‌موبایل‌جایزان",
            "outbounds": [
                "📌خودکار"
            ]
        },
        {
            "type": "urltest",
            "tag": "📌خودکار",
            "outbounds": []
        },
        {
            "type": "dns",
            "tag": "dns-out"
        },
        {
            "type": "direct",
            "tag": "direct"
        },
        {
            "type": "block",
            "tag": "block"
        }
    ],
    "route": {
        "auto_detect_interface": true,
        "geosite": {
            "path": "iran-geosite.db",
            "download_url": "https://github.com/bootmortis/iran-hosted-domains/releases/latest/download/iran-geosite.db"
        },
        "rules": [
            {
                "geosite": "category-ads-all",
                "outbound": "block"
            },
            {
                "outbound": "dns-out",
                "protocol": "dns"
            },
            {
                "clash_mode": "مستقیم",
                "outbound": "direct"
            },
            {
                "clash_mode": "جهانی",
                "outbound": "💉دکتر‌موبایل‌جایزان"
            },
            {
                "geosite": "ir",
                "outbound": "direct"
            },
            {
                "geosite": "ads",
                "outbound": "block"
            },
            {
                "domain_suffix": [
                    ".ir",
                    "safebrowsing.urlsec.qq.com",
                    "safebrowsing.googleapis.com",
                    "mzstatic.com",
                    "itunes.apple.com",
                    "apple-dns.net",
                    "digicert.com",
                    "speedtest.net",
                    "icloud.com",
                    "icloud-content.com",
                    "me.com",
                    "aaplimg.com",
                    "cdn20.com",
                    "cdn-apple.com",
                    "akadns.net",
                    "akamaiedge.net",
                    "edgekey.net",
                    "mwcloudcdn.com",
                    "mwcname.com",
                    "apple.com",
                    "apple-cloudkit.com",
                    "apple-mapkit.com"
                ],
                "outbound": "direct"
            },
            {
                "domain_keyword": [
                    "icloud"
                ],
                "outbound": "direct"
            },
            {
                "domain": [
                    "cvws.icloud-content.com",
                    "www.speedtest.net",
                    "developer.apple.com",
                    "ocsp.apple.com",
                    "ocsp.comodoca.com",
                    "ocsp.usertrust.com",
                    "ocsp.sectigo.com",
                    "ocsp.verisign.net",
                    "sandbox.itunes.apple.com",
                    "testflight.apple.com"
                ],
                "outbound": "direct"
            }
        ]
    }
}
